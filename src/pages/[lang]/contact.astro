---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n/translations';
import { langCodes } from '../../i18n/languages';
import { contactContent } from '../../i18n/contactContent';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang as keyof typeof translations].contact;
const c = contactContent[lang as keyof typeof contactContent];
---
<Layout lang={lang} title={`${t.title}, Vertoq`} description={t.metaDescription} path="contact">
  <section class="page-head">
    <p class="eyebrow">Vertoq</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <div class="content-block-group">
    <section class="content-block">
      <h2>{t.emailLabel}</h2>
      <p><a href="mailto:info@vertoq.net">info@vertoq.net</a></p>
      <p>{t.responseNote}</p>
    </section>

    {c && (
      <>
        <section class="content-block">
          <h2>{c.reasons.heading}</h2>
          <p>{c.reasons.body}</p>
        </section>

        <section class="content-block">
          <h2>{c.bugReports.heading}</h2>
          <p>{c.bugReports.body}</p>
        </section>
      </>
    )}
  </div>
</Layout>
