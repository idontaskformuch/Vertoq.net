---
import Layout from '../../layouts/Layout.astro';
import { langCodes } from '../../i18n/languages';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---
<Layout lang={lang} title="About, Vertoq" description="About Vertoq" path="about">
  <section class="page-head">
    <p class="eyebrow">Vertoq</p>
    <h1>About Us</h1>
    <p>Welcome to Vertoq, your go to destination for fast and accurate calculations.</p>
    <p>Vertoq is built with a focus on simplicity, speed and accuracy  in 10 languages.</p>
    <p>Thank you for making us a part of your daily routine!</p>
  </section>
</Layout>