---
import Layout from '../../../layouts/Layout.astro';
import { translations } from '../../../i18n/translations';
import { langCodes } from '../../../i18n/languages';
import { salaryContent } from '../../../i18n/salaryContent';
import SalaryCalculator from '../../../components/SalaryCalculator.astro';
import FaqSection from '../../../components/FaqSection.astro';
import AdSlot from '../../../components/AdSlot.astro';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang as keyof typeof translations].salary;
const c = salaryContent[lang as keyof typeof salaryContent];
---
<Layout lang={lang} title={`${t.title}, Vertoq`} description={t.metaDescription} path="salary">
  <section class="page-head">
    <p class="eyebrow">Vertoq</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <SalaryCalculator lang={lang} />

  {c && (
    <div class="content-block-group">
      <section class="content-block">
        <h2>{c.whatIsSalary.heading}</h2>
        <p>{c.whatIsSalary.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.effectiveRate.heading}</h2>
        <p>{c.effectiveRate.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.limitations.heading}</h2>
        <p>{c.limitations.body}</p>
      </section>

      <section class="content-block related-calculators">
        <h2>{c.related.heading}</h2>
        <p>
          <a href={`/${lang}/percent/`}>{c.related.linkText}</a> {c.related.description}
        </p>
      </section>
    </div>
  )}

  <FaqSection lang={lang} tool="salary" />

  <AdSlot />
</Layout>
