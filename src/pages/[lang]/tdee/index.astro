---
import Layout from '../../../layouts/Layout.astro';
import { translations } from '../../../i18n/translations';
import { langCodes } from '../../../i18n/languages';
import { tdeeContent } from '../../../i18n/tdeeContent';
import TdeeCalculator from '../../../components/TdeeCalculator.astro';
import FaqSection from '../../../components/FaqSection.astro';
import AdSlot from '../../../components/AdSlot.astro';
import ToolSchema from '../../../components/ToolSchema.astro';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang as keyof typeof translations].tdee;
const c = tdeeContent[lang as keyof typeof tdeeContent];
---
<Layout lang={lang} title={`${t.title}, Vertoq`} description={t.metaDescription} path="tdee">
  <section class="page-head">
    <p class="eyebrow">Vertoq</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <TdeeCalculator lang={lang} />

  {c && (
    <div class="content-block-group">
      <section class="content-block">
        <h2>{c.whatIsTdee.heading}</h2>
        <p>{c.whatIsTdee.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.formula.heading}</h2>
        <p><strong>{c.formula.mifflinLabel}</strong> {c.formula.mifflinNote}</p>
        <p>{c.formula.maleLabel} <code>{c.formula.mifflinMaleCode}</code></p>
        <p>{c.formula.femaleLabel} <code>{c.formula.mifflinFemaleCode}</code></p>
        <p><strong>{c.formula.harrisLabel}</strong> {c.formula.harrisNote}</p>
        <p>{c.formula.maleLabel} <code>{c.formula.harrisMaleCode}</code></p>
        <p>{c.formula.femaleLabel} <code>{c.formula.harrisFemaleCode}</code></p>
      </section>

      <section class="content-block">
        <h2>{c.activityTable.heading}</h2>
        <p>{c.activityTable.intro}</p>
        <div class="table-scroll">
          <table class="data-table">
            <thead>
              <tr><th>{c.activityTable.levelHeader}</th><th>{c.activityTable.multiplierHeader}</th></tr>
            </thead>
            <tbody>
              {c.activityTable.rows.map(([level, multiplier]) => (
                <tr><td>{level}</td><td>{multiplier}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-block">
        <h2>{c.useCase.heading}</h2>
        <p>{c.useCase.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.limitations.heading}</h2>
        <p>{c.limitations.body}</p>
      </section>

      <section class="content-block related-calculators">
        <h2>{c.related.heading}</h2>
        <p>
          <a href={`/${lang}/bmi/`}>{c.related.linkText}</a> {c.related.description}
        </p>
        <p>
          <a href={`/${lang}/calorie/`}>{c.related.calorieLinkText}</a> {c.related.calorieDescription}
        </p>
      </section>
    </div>
  )}

  <FaqSection lang={lang} tool="tdee" />

  <ToolSchema lang={lang} tool="tdee" path="tdee" title={t.title} description={t.metaDescription} />

  <AdSlot />
</Layout>
