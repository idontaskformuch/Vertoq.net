---
import Layout from '../../../layouts/Layout.astro';
import { translations } from '../../../i18n/translations';
import { langCodes } from '../../../i18n/languages';
import { loanCostContent } from '../../../i18n/loanCostContent';
import LoanCostCalculator from '../../../components/LoanCostCalculator.astro';
import FaqSection from '../../../components/FaqSection.astro';
import AdSlot from '../../../components/AdSlot.astro';
import ToolSchema from '../../../components/ToolSchema.astro';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang as keyof typeof translations].loancost;
const c = loanCostContent[lang as keyof typeof loanCostContent];
---
<Layout lang={lang} title={`${t.title}, Vertoq`} description={t.metaDescription} path="loancost">
  <section class="page-head">
    <p class="eyebrow">Vertoq</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <LoanCostCalculator lang={lang} />

  {c && (
    <div class="content-block-group">
      <section class="content-block">
        <h2>{c.whatIsLoanCost.heading}</h2>
        <p>{c.whatIsLoanCost.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.formula.heading}</h2>
        <p>{c.formula.intro}</p>
        <p><code>{c.formula.code}</code></p>
        <p>{c.formula.note}</p>
      </section>

      <section class="content-block">
        <h2>{c.amortization.heading}</h2>
        <p>{c.amortization.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.factors.heading}</h2>
        <p>{c.factors.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.limitations.heading}</h2>
        <p>{c.limitations.body}</p>
      </section>

      <section class="content-block related-calculators">
        <h2>{c.related.heading}</h2>
        <p>
          <a href={`/${lang}/loan/`}>{c.related.linkText}</a> {c.related.description}
        </p>
      </section>
    </div>
  )}

  <FaqSection lang={lang} tool="loancost" />

  <ToolSchema lang={lang} tool="loancost" path="loancost" title={t.title} description={t.metaDescription} />

  <AdSlot />
</Layout>
