---
import Layout from '../../../layouts/Layout.astro';
import { translations } from '../../../i18n/translations';
import { langCodes } from '../../../i18n/languages';
import { bodyFatContent } from '../../../i18n/bodyFatContent';
import BodyFatCalculator from '../../../components/BodyFatCalculator.astro';
import FaqSection from '../../../components/FaqSection.astro';
import AdSlot from '../../../components/AdSlot.astro';
import ToolSchema from '../../../components/ToolSchema.astro';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang as keyof typeof translations].bodyfat;
const c = bodyFatContent[lang as keyof typeof bodyFatContent];
---
<Layout lang={lang} title={`${t.title}, Vertoq`} description={t.metaDescription} path="bodyfat">
  <section class="page-head">
    <p class="eyebrow">Vertoq</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <BodyFatCalculator lang={lang} />

  {c && (
    <div class="content-block-group">
      <section class="content-block">
        <h2>{c.whatIsBodyFat.heading}</h2>
        <p>{c.whatIsBodyFat.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.method.heading}</h2>
        <p>{c.method.intro}</p>
        <p>{c.method.maleLabel} <code>{c.method.maleCode}</code></p>
        <p>{c.method.femaleLabel} <code>{c.method.femaleCode}</code></p>
        <p>{c.method.note}</p>
      </section>

      <section class="content-block">
        <h2>{c.ranges.heading}</h2>
        <p>{c.ranges.intro}</p>
        <div class="table-scroll">
          <table class="data-table">
            <thead>
              <tr><th>{c.ranges.categoryHeader}</th><th>{c.ranges.menHeader}</th><th>{c.ranges.womenHeader}</th></tr>
            </thead>
            <tbody>
              {c.ranges.rows.map(([category, men, women]) => (
                <tr><td>{category}</td><td>{men}</td><td>{women}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-block">
        <h2>{c.limitations.heading}</h2>
        <p>{c.limitations.body}</p>
      </section>

      <section class="content-block related-calculators">
        <h2>{c.related.heading}</h2>
        <p>
          <a href={`/${lang}/bmi/`}>{c.related.linkText}</a> {c.related.description}
        </p>
        <p>
          <a href={`/${lang}/idealweight/`}>{c.related.idealweightLinkText}</a> {c.related.idealweightDescription}
        </p>
      </section>
    </div>
  )}

  <FaqSection lang={lang} tool="bodyfat" />

  <ToolSchema lang={lang} tool="bodyfat" path="bodyfat" title={t.title} description={t.metaDescription} />

  <AdSlot />
</Layout>
