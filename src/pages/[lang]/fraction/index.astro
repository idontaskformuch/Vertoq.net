---
import Layout from '../../../layouts/Layout.astro';
import { translations } from '../../../i18n/translations';
import { langCodes } from '../../../i18n/languages';
import { fractionContent } from '../../../i18n/fractionContent';
import FractionCalculator from '../../../components/FractionCalculator.astro';
import FaqSection from '../../../components/FaqSection.astro';
import AdSlot from '../../../components/AdSlot.astro';
import ToolSchema from '../../../components/ToolSchema.astro';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang as keyof typeof translations].fraction;
const c = fractionContent[lang as keyof typeof fractionContent];
---
<Layout lang={lang} title={`${t.title}, Vertoq`} description={t.metaDescription} path="fraction">
  <section class="page-head">
    <p class="eyebrow">Vertoq</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <FractionCalculator lang={lang} />

  {c && (
    <div class="content-block-group">
      <section class="content-block">
        <h2>{c.whatIsFraction.heading}</h2>
        <p>{c.whatIsFraction.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.operations.heading}</h2>
        <p>{c.operations.addSub}</p>
        <p>{c.operations.mulDiv}</p>
      </section>

      <section class="content-block">
        <h2>{c.simplifying.heading}</h2>
        <p>{c.simplifying.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.mixedNumbers.heading}</h2>
        <p>{c.mixedNumbers.body}</p>
      </section>

      <section class="content-block related-calculators">
        <h2>{c.related.heading}</h2>
        <p>
          <a href={`/${lang}/percent/`}>{c.related.linkText}</a> {c.related.description}
        </p>
      </section>
    </div>
  )}

  <FaqSection lang={lang} tool="fraction" />

  <ToolSchema lang={lang} tool="fraction" path="fraction" title={t.title} description={t.metaDescription} />

  <AdSlot />
</Layout>
