---
import Layout from '../../../layouts/Layout.astro';
import { translations } from '../../../i18n/translations';
import { langCodes } from '../../../i18n/languages';
import { timeContent } from '../../../i18n/timeContent';
import TimeCalculator from '../../../components/TimeCalculator.astro';
import FaqSection from '../../../components/FaqSection.astro';
import AdSlot from '../../../components/AdSlot.astro';
import ToolSchema from '../../../components/ToolSchema.astro';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang as keyof typeof translations].time;
const c = timeContent[lang as keyof typeof timeContent];
---
<Layout lang={lang} title={`${t.title}, Vertoq`} description={t.metaDescription} path="time">
  <section class="page-head">
    <p class="eyebrow">Vertoq</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <TimeCalculator lang={lang} />

  {c && (
    <div class="content-block-group">
      <section class="content-block">
        <h2>{c.whatItCalculates.heading}</h2>
        <p>{c.whatItCalculates.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.howItWorks.heading}</h2>
        <p><strong>{c.howItWorks.leapYearLabel}</strong> {c.howItWorks.leapYearBody}</p>
        <p><strong>{c.howItWorks.monthLengthLabel}</strong> {c.howItWorks.monthLengthBody}</p>
        <p><strong>{c.howItWorks.timezoneLabel}</strong> {c.howItWorks.timezoneBody}</p>
      </section>

      <section class="content-block">
        <h2>{c.useCases.heading}</h2>
        <p>{c.useCases.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.limitations.heading}</h2>
        <p>{c.limitations.body}</p>
      </section>

      <section class="content-block related-calculators">
        <h2>{c.related.heading}</h2>
        <p>
          <a href={`/${lang}/age/`}>{c.related.linkText}</a> {c.related.description}
        </p>
      </section>
    </div>
  )}

  <FaqSection lang={lang} tool="time" />

  <ToolSchema lang={lang} tool="time" path="time" title={t.title} description={t.metaDescription} />

  <AdSlot />
</Layout>
