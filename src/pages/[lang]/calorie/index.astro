---
import Layout from '../../../layouts/Layout.astro';
import { translations } from '../../../i18n/translations';
import { langCodes } from '../../../i18n/languages';
import { calorieContent } from '../../../i18n/calorieContent';
import CalorieCalculator from '../../../components/CalorieCalculator.astro';
import FaqSection from '../../../components/FaqSection.astro';
import AdSlot from '../../../components/AdSlot.astro';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang as keyof typeof translations].calorie;
const c = calorieContent[lang as keyof typeof calorieContent];
---
<Layout lang={lang} title={`${t.title}, Vertoq`} description={t.metaDescription} path="calorie">
  <section class="page-head">
    <p class="eyebrow">Vertoq</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <CalorieCalculator lang={lang} />

  {c && (
    <div class="content-block-group">
      <section class="content-block">
        <h2>{c.whatIsCalorie.heading}</h2>
        <p>{c.whatIsCalorie.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.rule.heading}</h2>
        <p>{c.rule.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.ranges.heading}</h2>
        <p>{c.ranges.intro}</p>
        <div class="table-scroll">
          <table class="data-table">
            <thead>
              <tr><th>{c.ranges.goalHeader}</th><th>{c.ranges.rangeHeader}</th></tr>
            </thead>
            <tbody>
              {c.ranges.rows.map(([goal, range]) => (
                <tr><td>{goal}</td><td>{range}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
        <p>{c.ranges.note}</p>
      </section>

      <section class="content-block">
        <h2>{c.caution.heading}</h2>
        <p>{c.caution.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.limitations.heading}</h2>
        <p>{c.limitations.body}</p>
      </section>

      <section class="content-block related-calculators">
        <h2>{c.related.heading}</h2>
        <p>
          <a href={`/${lang}/tdee/`}>{c.related.tdeeLinkText}</a> {c.related.tdeeDescription}
        </p>
        <p>
          <a href={`/${lang}/bmr/`}>{c.related.bmrLinkText}</a> {c.related.bmrDescription}
        </p>
        <p>
          <a href={`/${lang}/bodyfat/`}>{c.related.bodyfatLinkText}</a> {c.related.bodyfatDescription}
        </p>
      </section>
    </div>
  )}

  <FaqSection lang={lang} tool="calorie" />

  <AdSlot />
</Layout>
