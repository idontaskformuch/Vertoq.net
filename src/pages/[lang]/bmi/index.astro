---
import Layout from '../../../layouts/Layout.astro';
import { translations } from '../../../i18n/translations';
import { langCodes } from '../../../i18n/languages';
import { bmiContent } from '../../../i18n/bmiContent';
import BmiCalculator from '../../../components/BmiCalculator.astro';
import FaqSection from '../../../components/FaqSection.astro';
import AdSlot from '../../../components/AdSlot.astro';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang as keyof typeof translations].bmi;
const c = bmiContent[lang as keyof typeof bmiContent];
---
<Layout lang={lang} title={`${t.title}, Vertoq`} description={t.metaDescription} path="bmi">
  <section class="page-head">
    <p class="eyebrow">Vertoq</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <BmiCalculator lang={lang} />

  {c && (
    <div class="content-block-group">
      <section class="content-block">
        <h2>{c.whatIsBmi.heading}</h2>
        <p>{c.whatIsBmi.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.whoTable.heading}</h2>
        <div class="table-scroll">
          <table class="data-table">
            <thead>
              <tr><th>{c.whoTable.categoryHeader}</th><th>{c.whoTable.rangeHeader}</th></tr>
            </thead>
            <tbody>
              {c.whoTable.rows.map(([category, range]) => (
                <tr><td>{category}</td><td>{range}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="source-note">{c.whoTable.source}</p>
      </section>

      <section class="content-block">
        <h2>{c.children.heading}</h2>
        <p>{c.children.intro}</p>
        <div class="table-scroll">
          <table class="data-table">
            <thead>
              <tr><th>{c.children.categoryHeader}</th><th>{c.children.percentileHeader}</th></tr>
            </thead>
            <tbody>
              {c.children.rows.map(([category, percentile]) => (
                <tr><td>{category}</td><td>{percentile}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="source-note">{c.children.source}</p>
      </section>

      <section class="content-block">
        <h2>{c.formula.heading}</h2>
        <p><strong>{c.formula.metricFormulaLabel}</strong> <code>{c.formula.metricFormulaCode}</code></p>
        <p><strong>{c.formula.usFormulaLabel}</strong> <code>{c.formula.usFormulaCode}</code></p>
        <h3>{c.formula.exampleHeading}</h3>
        <p set:html={c.formula.metricExampleHtml} />
        <p set:html={c.formula.usExampleHtml} />
      </section>

      <section class="content-block">
        <h2>{c.bmiPrime.heading}</h2>
        <p set:html={c.bmiPrime.bodyHtml} />
      </section>

      <section class="content-block">
        <h2>{c.healthRisk.heading}</h2>
        <p>{c.healthRisk.body}</p>
        <p class="source-note">{c.healthRisk.source}</p>
      </section>

      <section class="content-block">
        <h2>{c.limitations.heading}</h2>
        <p><strong>{c.limitations.adultsLabel}</strong> {c.limitations.adultsBody}</p>
        <p><strong>{c.limitations.childrenLabel}</strong> {c.limitations.childrenBody}</p>
      </section>

      <section class="content-block related-calculators">
        <h2>{c.related.heading}</h2>
        <p>
          <a href={`/${lang}/tdee/`}>{c.related.linkText}</a> {c.related.description}
        </p>
      </section>
    </div>
  )}

  <FaqSection lang={lang} tool="bmi" />

  <AdSlot />
</Layout>
