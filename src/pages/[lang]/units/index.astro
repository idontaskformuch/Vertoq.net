---
import Layout from '../../../layouts/Layout.astro';
import { translations } from '../../../i18n/translations';
import { langCodes } from '../../../i18n/languages';
import { unitsContent } from '../../../i18n/unitsContent';
import UnitConverter from '../../../components/UnitConverter.astro';
import FaqSection from '../../../components/FaqSection.astro';
import AdSlot from '../../../components/AdSlot.astro';
import ToolSchema from '../../../components/ToolSchema.astro';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang as keyof typeof translations].units;
const c = unitsContent[lang as keyof typeof unitsContent];
---
<Layout lang={lang} title={`${t.title}, Vertoq`} description={t.metaDescription} path="units">
  <section class="page-head">
    <p class="eyebrow">Vertoq</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <UnitConverter lang={lang} />

  {c && (
    <div class="content-block-group">
      <section class="content-block">
        <h2>{c.whatIsConverter.heading}</h2>
        <p>{c.whatIsConverter.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.categoriesOverview.heading}</h2>
        <p>{c.categoriesOverview.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.temperature.heading}</h2>
        <p>{c.temperature.body}</p>
        <p><code>{c.temperature.code}</code></p>
      </section>

      <section class="content-block">
        <h2>{c.accuracy.heading}</h2>
        <p>{c.accuracy.body}</p>
      </section>

      <section class="content-block related-calculators">
        <h2>{c.related.heading}</h2>
        <p>
          <a href={`/${lang}/percent/`}>{c.related.linkText}</a> {c.related.description}
        </p>
      </section>
    </div>
  )}

  <FaqSection lang={lang} tool="units" />

  <ToolSchema lang={lang} tool="units" path="units" title={t.title} description={t.metaDescription} />

  <AdSlot />
</Layout>
