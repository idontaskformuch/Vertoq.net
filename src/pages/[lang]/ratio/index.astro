---
import Layout from '../../../layouts/Layout.astro';
import { translations } from '../../../i18n/translations';
import { langCodes } from '../../../i18n/languages';
import { ratioContent } from '../../../i18n/ratioContent';
import RatioCalculator from '../../../components/RatioCalculator.astro';
import FaqSection from '../../../components/FaqSection.astro';
import AdSlot from '../../../components/AdSlot.astro';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang as keyof typeof translations].ratio;
const c = ratioContent[lang as keyof typeof ratioContent];
---
<Layout lang={lang} title={`${t.title}, Vertoq`} description={t.metaDescription} path="ratio">
  <section class="page-head">
    <p class="eyebrow">Vertoq</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <RatioCalculator lang={lang} />

  {c && (
    <div class="content-block-group">
      <section class="content-block">
        <h2>{c.whatIsRatio.heading}</h2>
        <p>{c.whatIsRatio.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.simplifying.heading}</h2>
        <p>{c.simplifying.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.proportions.heading}</h2>
        <p>{c.proportions.body}</p>
      </section>

      <section class="content-block">
        <h2>{c.useCases.heading}</h2>
        <p>{c.useCases.body}</p>
      </section>

      <section class="content-block related-calculators">
        <h2>{c.related.heading}</h2>
        <p>
          <a href={`/${lang}/fraction/`}>{c.related.linkText}</a> {c.related.description}
        </p>
      </section>
    </div>
  )}

  <FaqSection lang={lang} tool="ratio" />

  <AdSlot />
</Layout>
