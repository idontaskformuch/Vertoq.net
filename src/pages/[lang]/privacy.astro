---
import Layout from '../../layouts/Layout.astro';
import { langCodes } from '../../i18n/languages';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
---
<Layout
  lang={lang}
  title="Privacy Policy, Vertoq"
  description="Privacy policy for Vertoq.net"
  path="privacy"
>
  <main style="padding: 2rem; max-width: 800px; margin: 0 auto; line-height: 1.6;">
    <h1>Privacy Policy</h1>
    <p><strong>Last updated: July 5, 2026</strong></p>
    <p>At Vertoq, we prioritize your privacy and are committed to transparency.</p>
    <h2>1. Information We Collect</h2>
    <p>We collect basic log data (IP address, browser type) and use cookies to improve your experience.</p>
    <h2>2. Advertising and Google AdSense</h2>
    <p>We use Google AdSense to serve advertisements. Google, as a third-party vendor, uses cookies for interest-based advertising.</p>
    <h2>3. GDPR & CCPA Compliance</h2>
    <p>For users in the EEA, we process data based on transparency and consent.</p>
    <h2>4. Contact Us</h2>
    <p>If you have any questions, contact us at: <a href="mailto:info@vertoq.net">info@vertoq.net</a></p>
  </main>
</Layout>