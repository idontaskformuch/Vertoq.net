---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n/translations';
import { langCodes } from '../../i18n/languages';
import { privacyContent } from '../../i18n/privacyContent';

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = translations[lang as keyof typeof translations].privacy;
const c = privacyContent[lang as keyof typeof privacyContent];
---
<Layout lang={lang} title={`${t.title}, Vertoq`} description={t.metaDescription} path="privacy">
  <section class="page-head">
    <p class="eyebrow">Vertoq</p>
    <h1>{t.title}</h1>
    <p>{t.intro}</p>
  </section>

  <div class="content-block-group">
    <section class="content-block">
      <p><strong>{c.lastUpdated}</strong></p>
      <p>{c.intro}</p>
    </section>

    <section class="content-block">
      <h2>{c.dataCollection.heading}</h2>
      <p>{c.dataCollection.body}</p>
    </section>

    <section class="content-block">
      <h2>{c.cookies.heading}</h2>
      <p>{c.cookies.intro}</p>
      <h3>{c.cookies.necessaryHeading}</h3>
      <p>{c.cookies.necessaryBody}</p>
      <h3>{c.cookies.advertisingHeading}</h3>
      <p>{c.cookies.advertisingBody}</p>
    </section>

    <section class="content-block">
      <h2>{c.thirdParty.heading}</h2>
      <p>{c.thirdParty.cloudflareBody}</p>
      <p>{c.thirdParty.adsenseBody}</p>
    </section>

    <section class="content-block">
      <h2>{c.yourChoices.heading}</h2>
      <p>{c.yourChoices.body}</p>
    </section>

    <section class="content-block">
      <h2>{c.gdpr.heading}</h2>
      <p>{c.gdpr.body}</p>
    </section>

    <section class="content-block">
      <h2>{c.changes.heading}</h2>
      <p>{c.changes.body}</p>
    </section>

    <section class="content-block">
      <h2>{c.contact.heading}</h2>
      <p>{c.contact.body} <a href="mailto:info@vertoq.net">info@vertoq.net</a></p>
    </section>
  </div>
</Layout>
