---
import { translations } from '../i18n/translations';

interface Props { lang: string; }
const { lang } = Astro.props as Props;
const t = translations[lang as keyof typeof translations].ratio;
---
<div class="converter" id="ratio-calc">
  <div class="conv-grid">
    <div class="field">
      <label for="ra-a">{t.aLabel}</label>
      <input id="ra-a" type="number" value="2" step="any" inputmode="decimal" />
    </div>
    <span>:</span>
    <div class="field">
      <label for="ra-b">{t.bLabel}</label>
      <input id="ra-b" type="number" value="3" step="any" inputmode="decimal" />
    </div>
  </div>

  <div class="result-row" style="margin-top:14px">
    <span class="label">{t.simplifiedLabel}</span>
    <span class="value" id="ra-simplified">—</span>
  </div>

  <div class="field" style="margin-top:24px">
    <label for="ra-c">{t.knownCLabel}</label>
    <input id="ra-c" type="number" value="5" step="any" inputmode="decimal" />
  </div>

  <div class="result-row" style="margin-top:14px">
    <span class="label">{t.resultXLabel}</span>
    <span class="value" id="ra-x">—</span>
  </div>
  <p class="calc-error" id="ra-error" style="display:none">{t.errorMessage}</p>
</div>

<script>
  const aEl = document.getElementById('ra-a') as HTMLInputElement;
  const bEl = document.getElementById('ra-b') as HTMLInputElement;
  const cEl = document.getElementById('ra-c') as HTMLInputElement;
  const simplifiedEl = document.getElementById('ra-simplified')!;
  const xEl = document.getElementById('ra-x')!;
  const errorEl = document.getElementById('ra-error')!;

  function gcd(a: number, b: number): number {
    a = Math.abs(a);
    b = Math.abs(b);
    while (b) {
      [a, b] = [b, a % b];
    }
    return a || 1;
  }

  function fmt(n: number) {
    if (!isFinite(n)) return '—';
    return (Math.round(n * 1000000) / 1000000).toString();
  }

  function calc() {
    const a = parseFloat(aEl.value);
    const b = parseFloat(bEl.value);
    const c = parseFloat(cEl.value);

    if (isNaN(a) || isNaN(b) || isNaN(c) || a === 0 || b === 0) {
      simplifiedEl.textContent = '—';
      xEl.textContent = '—';
      errorEl.style.display = 'block';
      return;
    }

    errorEl.style.display = 'none';

    if (Number.isInteger(a) && Number.isInteger(b)) {
      const divisor = gcd(a, b);
      simplifiedEl.textContent = `${a / divisor} : ${b / divisor}`;
    } else {
      simplifiedEl.textContent = `${fmt(a)} : ${fmt(b)}`;
    }

    const x = (b * c) / a;
    xEl.textContent = fmt(x);
  }

  [aEl, bEl, cEl].forEach((el) => el.addEventListener('input', calc));
  calc();

  // Enter-navigering: triggar beräkning och hoppar till nästa fält
  (function() {
    const container = document.querySelector('.converter');
    if (!container) return;
    const focusables = () => Array.from(container.querySelectorAll<HTMLElement>('input, select, button'));
    container.addEventListener('keydown', function(e: KeyboardEvent) {
      if (e.key !== 'Enter') return;
      const el = e.target as HTMLElement;
      if (!['INPUT', 'SELECT'].includes(el.tagName)) return;
      e.preventDefault();
      el.dispatchEvent(new Event('input', { bubbles: true }));
      el.dispatchEvent(new Event('change', { bubbles: true }));
      const list = focusables();
      const idx = list.indexOf(el);
      if (idx >= 0 && idx < list.length - 1) list[idx + 1].focus();
    });
  })();
</script>
