---
import { translations } from '../i18n/translations';

interface Props { lang: string; }
const { lang } = Astro.props as Props;
const t = translations[lang as keyof typeof translations].fraction;

const opLabels = JSON.stringify(t.operations);
---
<div class="converter" id="fraction-calc">
  <div class="conv-grid">
    <div class="field">
      <label for="fr-num1">{t.numLabel} 1</label>
      <input id="fr-num1" type="number" value="1" step="1" inputmode="numeric" />
    </div>
    <span>/</span>
    <div class="field">
      <label for="fr-den1">{t.denLabel} 1</label>
      <input id="fr-den1" type="number" value="2" step="1" inputmode="numeric" />
    </div>
  </div>

  <div class="field" style="margin-top:14px">
    <label for="fr-op">{t.operationLabel}</label>
    <select id="fr-op">
      <option value="add">{t.operations.add}</option>
      <option value="subtract">{t.operations.subtract}</option>
      <option value="multiply">{t.operations.multiply}</option>
      <option value="divide">{t.operations.divide}</option>
    </select>
  </div>

  <div class="conv-grid" style="margin-top:14px">
    <div class="field">
      <label for="fr-num2">{t.numLabel} 2</label>
      <input id="fr-num2" type="number" value="1" step="1" inputmode="numeric" />
    </div>
    <span>/</span>
    <div class="field">
      <label for="fr-den2">{t.denLabel} 2</label>
      <input id="fr-den2" type="number" value="3" step="1" inputmode="numeric" />
    </div>
  </div>

  <div class="result-row" style="margin-top:24px">
    <span class="label">{t.resultLabel}</span>
    <span class="value" id="fr-result">—</span>
  </div>
  <div class="result-row">
    <span class="label">{t.decimalLabel}</span>
    <span class="value" id="fr-decimal" style="font-size:1.3rem">—</span>
  </div>
  <p class="calc-error" id="fr-error" style="display:none">{t.errorMessage}</p>
</div>

<script define:vars={{ opLabels }}>
  const num1El = document.getElementById('fr-num1');
  const den1El = document.getElementById('fr-den1');
  const opEl = document.getElementById('fr-op');
  const num2El = document.getElementById('fr-num2');
  const den2El = document.getElementById('fr-den2');
  const resultEl = document.getElementById('fr-result');
  const decimalEl = document.getElementById('fr-decimal');
  const errorEl = document.getElementById('fr-error');

  function gcd(a, b) {
    a = Math.abs(a);
    b = Math.abs(b);
    while (b) {
      [a, b] = [b, a % b];
    }
    return a || 1;
  }

  function clearResults() {
    resultEl.textContent = '—';
    decimalEl.textContent = '—';
  }

  function calc() {
    const n1 = parseInt(num1El.value, 10);
    const d1 = parseInt(den1El.value, 10);
    const op = opEl.value;
    const n2 = parseInt(num2El.value, 10);
    const d2 = parseInt(den2El.value, 10);

    if (isNaN(n1) || isNaN(d1) || isNaN(n2) || isNaN(d2) || d1 === 0 || d2 === 0) {
      clearResults();
      errorEl.style.display = 'block';
      return;
    }

    if (op === 'divide' && n2 === 0) {
      clearResults();
      errorEl.style.display = 'block';
      return;
    }

    errorEl.style.display = 'none';

    let resultNum, resultDen;
    if (op === 'add') {
      resultNum = n1 * d2 + n2 * d1;
      resultDen = d1 * d2;
    } else if (op === 'subtract') {
      resultNum = n1 * d2 - n2 * d1;
      resultDen = d1 * d2;
    } else if (op === 'multiply') {
      resultNum = n1 * n2;
      resultDen = d1 * d2;
    } else {
      resultNum = n1 * d2;
      resultDen = d1 * n2;
    }

    if (resultDen < 0) {
      resultDen = -resultDen;
      resultNum = -resultNum;
    }

    const divisor = gcd(resultNum, resultDen);
    resultNum = resultNum / divisor;
    resultDen = resultDen / divisor;

    resultEl.textContent = `${resultNum} / ${resultDen}`;
    decimalEl.textContent = (Math.round((resultNum / resultDen) * 1000000) / 1000000).toString();
  }

  [num1El, den1El, opEl, num2El, den2El].forEach((el) => el.addEventListener('input', calc));
  calc();

  // Enter-navigering: triggar beräkning och hoppar till nästa fält
  (function() {
    const container = document.querySelector('.converter');
    if (!container) return;
    const focusables = () => Array.from(container.querySelectorAll('input, select, button'));
    container.addEventListener('keydown', function(e) {
      if (e.key !== 'Enter') return;
      const el = e.target;
      if (!['INPUT', 'SELECT'].includes(el.tagName)) return;
      e.preventDefault();
      el.dispatchEvent(new Event('input', { bubbles: true }));
      el.dispatchEvent(new Event('change', { bubbles: true }));
      const list = focusables();
      const idx = list.indexOf(el);
      if (idx >= 0 && idx < list.length - 1) list[idx + 1].focus();
    });
  })();
</script>
