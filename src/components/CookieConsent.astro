---
import { translations } from '../i18n/translations';

interface Props { lang: string; }
const { lang } = Astro.props as Props;
const t = translations[lang as keyof typeof translations].cookieConsent;
const privacyLabel = translations[lang as keyof typeof translations].nav.privacy;
---
<div class="cookie-banner" id="cookie-banner" role="dialog" aria-live="polite" aria-label={privacyLabel}>
  <p class="cookie-banner-text">
    {t.message}{' '}
    <a href={`/${lang}/privacy/`}>{t.privacyLink}</a>
  </p>
  <div class="cookie-banner-actions">
    <button type="button" id="cookie-necessary" class="cookie-btn cookie-btn-secondary">{t.necessaryOnly}</button>
    <button type="button" id="cookie-accept" class="cookie-btn cookie-btn-primary">{t.acceptAll}</button>
  </div>
</div>

<script>
  const STORAGE_KEY = 'vertoq-cookie-consent';

  function loadAdsense() {
    if (document.getElementById('adsbygoogle-script')) return;
    const script = document.createElement('script');
    script.id = 'adsbygoogle-script';
    script.async = true;
    script.crossOrigin = 'anonymous';
    script.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9173970727436631';
    document.head.appendChild(script);
  }

  function init() {
    const banner = document.getElementById('cookie-banner');
    if (!banner) return;

    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored === 'all') {
      loadAdsense();
      return;
    }
    if (stored === 'necessary') {
      return;
    }

    // No stored choice yet, show the banner
    banner.classList.add('visible');

    const acceptBtn = document.getElementById('cookie-accept');
    const necessaryBtn = document.getElementById('cookie-necessary');

    acceptBtn?.addEventListener('click', () => {
      localStorage.setItem(STORAGE_KEY, 'all');
      banner.classList.remove('visible');
      loadAdsense();
    });

    necessaryBtn?.addEventListener('click', () => {
      localStorage.setItem(STORAGE_KEY, 'necessary');
      banner.classList.remove('visible');
    });
  }

  init();
</script>
