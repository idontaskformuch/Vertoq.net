---
import { translations } from '../i18n/translations';

interface Props { lang: string; }
const { lang } = Astro.props as Props;
const t = translations[lang as keyof typeof translations];
const year = new Date().getFullYear();

const tools = [
  { href: 'units', label: t.nav.units },
  { href: 'time', label: t.nav.time },
  { href: 'percent', label: t.nav.percent },
  { href: 'age', label: t.nav.age },
  { href: 'bmi', label: t.nav.bmi },
  { href: 'tdee', label: t.tdee?.title || 'TDEE' },
  { href: 'bmr', label: t.bmr?.title || 'BMR' },
  { href: 'calorie', label: t.calorie?.title || 'Calorie Calculator' },
  { href: 'bodyfat', label: t.bodyfat?.title || 'Body Fat Calculator' },
  { href: 'idealweight', label: t.idealweight?.title || 'Ideal Weight Calculator' },
  { href: 'loan', label: t.nav.loan },
  { href: 'loancost', label: t.loancost?.title || 'Loan Cost' },
  { href: 'savingsgoal', label: t.savingsgoal?.title || 'Savings Goal Calculator' },
  { href: 'tip', label: t.tip?.title || 'Tip Calculator' },
  { href: 'salary', label: t.salary?.title || 'Net Income Calculator' },
  { href: 'fraction', label: t.fraction?.title || 'Fraction Calculator' },
  { href: 'ratio', label: t.ratio?.title || 'Ratio Calculator' },
  { href: 'stddev', label: t.stddev?.title || 'Standard Deviation Calculator' },
];
---

<footer class="site-footer">
  <div class="wrap" style="flex-direction:column; gap:14px;">
    <nav class="lang-switcher" aria-label="Alla verktyg">
      {tools.map((tool) => (
        tool.label && (
          <a href={`/${lang}/${tool.href}/`}>{tool.label}</a>
        )
      ))}
    </nav>
    <div style="display:flex; flex-wrap: wrap; justify-content:center; gap:16px;">
      <span>{t.siteName} &copy; {year}, {t.footer.rights}</span>
      <a href={`/${lang}/about`}>About</a>
      <a href={`/${lang}/contact`}>Contact</a>
      <a href={`/${lang}/privacy`}>Privacy Policy</a>
      <span>{t.footer.disclaimer}</span>
    </div>
  </div>
</footer>